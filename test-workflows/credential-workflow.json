{
  "name": "Credential Test Workflow",
  "active": true,
  "nodes": [
    {
      "name": "HTTP Request with Credentials",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "url": "https://httpbin.org/headers",
        "method": "GET",
        "authentication": "bearerToken",
        "bearerToken": "={{ $credential.apiKey }}"
      },
      "credentials": {
        "httpBearerAuth": {
          "id": "test-api-key-cred",
          "name": "Test API Key Credential",
          "type": "httpBearerAuth"
        }
      }
    }
  ],
  "connections": {}
}