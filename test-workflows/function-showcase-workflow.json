            },
            {
              "name": "power",
              "value": "={{ pow($json.quantity, 2) }}"
            },
            {
              "name": "squareRoot",
              "value": "={{ sqrt($json.total) }}"
            },
            {
              "name": "absolute",
              "value": "={{ abs(subtract($json.price, 200)) }}"
            }
          ],
          "string": [
            {
              "name": "mathSummary",
              "value": "={{ 'Price: $' + $json.rounded + ' x ' + $json.quantity + ' = $' + round($json.total, 2) }}"
            }
          ]
        }
      }
    },
