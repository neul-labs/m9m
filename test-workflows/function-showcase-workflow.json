    {
      "name": "String Functions",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [450, 200],
      "parameters": {
        "values": {
          "string": [
            {
              "name": "cleaned",
              "value": "={{ trim($json.text) }}"
            },
            {
              "name": "uppercase",
              "value": "={{ upper($json.cleaned) }}"
            },
            {
              "name": "lowercase",
              "value": "={{ lower($json.cleaned) }}"
            },
            {
              "name": "firstWord",
              "value": "={{ first(split($json.cleaned, ' ')) }}"
            },
            {
              "name": "initials",
              "value": "={{ join(pluck(split($json.cleaned, ' '), 0), '.') }}"
            },
            {
              "name": "encoded",
              "value": "={{ base64Encode($json.text) }}"
            },
            {
              "name": "hashed",
              "value": "={{ md5($json.email) }}"
            },
            {
              "name": "escaped",
              "value": "={{ escapeHtml($json.html) }}"
            }
          ]
        }
      }
    },
    {
      "name": "Math Functions",
