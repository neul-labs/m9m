{
  "name": "Conditional Logic Test",
  "active": true,
  "nodes": [
    {
      "name": "Start",
      "type": "n8n-nodes-base.start",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {}
    },
    {
      "name": "Logic Operations",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [450, 300],
      "parameters": {
        "assignments": [
          {
            "name": "ternaryResult",
            "value": "={{ $json.age >= 18 ? 'adult' : 'minor' }}"
          },
          {
            "name": "ifResult",
            "value": "={{ if($json.age >= 18, 'Can vote', 'Cannot vote') }}"
          },
          {
            "name": "emptyCheck",
            "value": "={{ isEmpty($json.emptyField) }}"
          },
          {
            "name": "notEmptyCheck",
            "value": "={{ isNotEmpty($json.firstName) }}"
          },
          {
            "name": "andResult",
            "value": "={{ and($json.age >= 18, isNotEmpty($json.firstName)) }}"
          },
          {
            "name": "orResult",
            "value": "={{ or($json.age < 18, isEmpty($json.lastName)) }}"
          }
        ]
      }
    }
  ],
  "connections": {
    "Start": {
      "main": [
        [
          {
            "node": "Logic Operations",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}