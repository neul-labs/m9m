{
  "name": "Array Functions Test",
  "active": true,
  "nodes": [
    {
      "name": "Start",
      "type": "n8n-nodes-base.start",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {}
    },
    {
      "name": "Array Operations",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [450, 300],
      "parameters": {
        "assignments": [
          {
            "name": "firstItem",
            "value": "={{ first($json.items) }}"
          },
          {
            "name": "lastItem",
            "value": "={{ last($json.items) }}"
          },
          {
            "name": "itemCount",
            "value": "={{ length($json.items) }}"
          },
          {
            "name": "joinedItems",
            "value": "={{ join($json.items, ', ') }}"
          },
          {
            "name": "maxNumber",
            "value": "={{ max($json.numbers) }}"
          },
          {
            "name": "minNumber",
            "value": "={{ min($json.numbers) }}"
          },
          {
            "name": "sumNumbers",
            "value": "={{ sum($json.numbers) }}"
          }
        ]
      }
    }
  ],
  "connections": {
    "Start": {
      "main": [
        [
          {
            "node": "Array Operations",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}