{
  "name": "Simple Expression Test",
  "active": true,
  "nodes": [
    {
      "name": "Start",
      "type": "n8n-nodes-base.start",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {}
    },
    {
      "name": "Set Values",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [450, 300],
      "parameters": {
        "assignments": [
          {
            "name": "fullName",
            "value": "={{ upper($json.firstName) }} {{ upper($json.lastName) }}"
          },
          {
            "name": "age",
            "value": "={{ $json.age }}"
          },
          {
            "name": "isAdult",
            "value": "={{ $json.age >= 18 }}"
          },
          {
            "name": "mathResult",
            "value": "={{ add(2, 3) }}"
          },
          {
            "name": "stringLength",
            "value": "={{ length($json.firstName) }}"
          }
        ]
      }
    }
  ],
  "connections": {
    "Start": {
      "main": [
        [
          {
            "node": "Set Values",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}