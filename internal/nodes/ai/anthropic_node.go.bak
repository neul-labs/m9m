package ai

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"time"

	"github.com/dipankar/n8n-go/internal/nodes/base"
)

// AnthropicNode provides Anthropic Claude API integration
type AnthropicNode struct {
	*base.BaseNode
	httpClient *http.Client
}

// NewAnthropicNode creates a new Anthropic node
func NewAnthropicNode() *AnthropicNode {
	return &AnthropicNode{
		BaseNode: base.NewBaseNode("Anthropic", "Anthropic Claude"),
		httpClient: &http.Client{
			Timeout: 60 * time.Second,
		},
	}
}

// GetMetadata returns the node metadata
func (n *AnthropicNode) GetMetadata() base.NodeMetadata {
	return base.NodeMetadata{
		Name:        "Anthropic",
		DisplayName: "Anthropic Claude",
		Description: "Use Anthropic's Claude models for advanced AI tasks",
		Group:       []string{"AI"},
		Version:     1,
		Inputs:      []string{"main"},
		Outputs:     []string{"main"},
		Credentials: []base.CredentialType{
			{
				Name:        "anthropicApi",
				Required:    true,
				DisplayName: "Anthropic API",
			},
		},
		Properties: []base.NodeProperty{
			{
				Name:        "model",
				DisplayName: "Model",
				Type:        "options",
				Options: []base.OptionItem{
					// Claude 3 models
					{Name: "Claude 3 Opus", Value: "claude-3-opus-20240229"},
					{Name: "Claude 3 Sonnet", Value: "claude-3-sonnet-20240229"},
					{Name: "Claude 3 Haiku", Value: "claude-3-haiku-20240307"},
					// Claude 2 models
					{Name: "Claude 2.1", Value: "claude-2.1"},
					{Name: "Claude 2.0", Value: "claude-2.0"},
					// Claude Instant
					{Name: "Claude Instant 1.2", Value: "claude-instant-1.2"},
				},
				Default:     "claude-3-sonnet-20240229",
				Required:    true,
				Description: "The Claude model to use",
			},
			{
				Name:        "prompt",
				DisplayName: "Prompt",
				Type:        "string",
				TypeOptions: map[string]interface{}{
					"rows": 5,
				},
				Default:     "",
				Required:    true,
				Description: "The prompt to send to Claude",
			},
			{
				Name:        "systemPrompt",
				DisplayName: "System Prompt",
				Type:        "string",
				TypeOptions: map[string]interface{}{
					"rows": 3,
				},
				Default:     "",
				Description: "System prompt to set Claude's behavior and context",
			},
			{
				Name:        "temperature",
				DisplayName: "Temperature",
				Type:        "number",
				TypeOptions: map[string]interface{}{
					"numberPrecision": 1,
					"minValue":        0,
					"maxValue":        1,
				},
				Default:     0.7,
				Description: "Controls randomness (0=deterministic, 1=creative)",
			},
			{
				Name:        "maxTokens",
				DisplayName: "Max Tokens",
				Type:        "number",
				Default:     4096,
				Description: "Maximum number of tokens to generate",
			},
			{
				Name:        "topP",
				DisplayName: "Top P",
				Type:        "number",
				TypeOptions: map[string]interface{}{
					"numberPrecision": 2,
					"minValue":        0,
					"maxValue":        1,
				},
				Default:     1,
				Description: "Nucleus sampling parameter",
			},
			{
				Name:        "topK",
				DisplayName: "Top K",
				Type:        "number",
				Default:     0,
				Description: "Only sample from top K options (0=disabled)",
			},
			{
				Name:        "stopSequences",
				DisplayName: "Stop Sequences",
				Type:        "string",
				Default:     "",
				Description: "Comma-separated sequences where the API will stop generating",
			},
			{
				Name:        "stream",
				DisplayName: "Stream",
				Type:        "boolean",
				Default:     false,
				Description: "Stream the response (not fully implemented)",
			},
		},
	}
}

// Execute runs the Anthropic operation
func (n *AnthropicNode) Execute(ctx context.Context, params base.ExecutionParams) (base.NodeOutput, error) {
	// Get credentials
	credentials, err := params.GetCredentials("anthropicApi")
	if err != nil {
		return base.NodeOutput{}, fmt.Errorf("failed to get Anthropic credentials: %w", err)
	}

	apiKey, ok := credentials["apiKey"].(string)
	if !ok || apiKey == "" {
		return base.NodeOutput{}, fmt.Errorf("Anthropic API key not found in credentials")
	}

	// Get parameters
	model := params.GetNodeParameter("model", "claude-3-sonnet-20240229").(string)
	prompt := params.GetNodeParameter("prompt", "").(string)
	systemPrompt := params.GetNodeParameter("systemPrompt", "").(string)
	temperature := params.GetNodeParameter("temperature", 0.7).(float64)
	maxTokens := params.GetNodeParameter("maxTokens", 4096).(int)
	topP := params.GetNodeParameter("topP", 1.0).(float64)
	topK := int(params.GetNodeParameter("topK", 0).(float64))
	stopSequencesStr := params.GetNodeParameter("stopSequences", "").(string)

	// Parse stop sequences
	var stopSequences []string
	if stopSequencesStr != "" {
		for _, seq := range strings.Split(stopSequencesStr, ",") {
			if trimmed := strings.TrimSpace(seq); trimmed != "" {
				stopSequences = append(stopSequences, trimmed)
			}
		}
	}

	// Get input data
	inputData := params.GetInputData()
	var outputItems []base.ItemData

	for _, item := range inputData {
		// Build messages
		messages := []map[string]interface{}{
			{
				"role":    "user",
				"content": prompt,
			},
		}

		// Build request body
		requestBody := map[string]interface{}{
			"model":      model,
			"messages":   messages,
			"max_tokens": maxTokens,
		}

		// Add optional parameters
		if systemPrompt != "" {
			requestBody["system"] = systemPrompt
		}
		if temperature != 0.7 {
			requestBody["temperature"] = temperature
		}
		if topP != 1.0 {
			requestBody["top_p"] = topP
		}
		if topK > 0 {
			requestBody["top_k"] = topK
		}
		if len(stopSequences) > 0 {
			requestBody["stop_sequences"] = stopSequences
		}

		// Make API request
		response, err := n.makeAnthropicRequest(apiKey, requestBody)
		if err != nil {
			return base.NodeOutput{}, fmt.Errorf("Anthropic API error: %w", err)
		}

		// Extract content
		content, ok := response["content"].([]interface{})
		if !ok || len(content) == 0 {
			return base.NodeOutput{}, fmt.Errorf("unexpected response format from Anthropic")
		}

		firstContent := content[0].(map[string]interface{})
		text := firstContent["text"].(string)

		// Build output
		outputItem := map[string]interface{}{
			"text":         text,
			"model":        response["model"],
			"stop_reason":  response["stop_reason"],
			"stop_sequence": response["stop_sequence"],
		}

		// Add usage information if available
		if usage, ok := response["usage"].(map[string]interface{}); ok {
			outputItem["usage"] = usage
		}

		outputItems = append(outputItems, base.ItemData{
			JSON:  outputItem,
			Index: item.Index,
		})
	}

	return base.NodeOutput{
		Items: outputItems,
	}, nil
}

// makeAnthropicRequest makes an HTTP request to Anthropic API
func (n *AnthropicNode) makeAnthropicRequest(apiKey string, body map[string]interface{}) (map[string]interface{}, error) {
	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, fmt.Errorf("failed to marshal request body: %w", err)
	}

	req, err := http.NewRequest("POST", "https://api.anthropic.com/v1/messages", bytes.NewBuffer(jsonBody))
	if err != nil {
		return nil, fmt.Errorf("failed to create request: %w", err)
	}

	// Set headers
	req.Header.Set("Content-Type", "application/json")
	req.Header.Set("x-api-key", apiKey)
	req.Header.Set("anthropic-version", "2023-06-01")

	// Make request
	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, fmt.Errorf("failed to make request: %w", err)
	}
	defer resp.Body.Close()

	// Read response
	respBody, err := io.ReadAll(resp.Body)
	if err != nil {
		return nil, fmt.Errorf("failed to read response body: %w", err)
	}

	// Handle errors
	if resp.StatusCode >= 400 {
		var errorResponse map[string]interface{}
		if err := json.Unmarshal(respBody, &errorResponse); err == nil {
			if errorDetail, ok := errorResponse["error"].(map[string]interface{}); ok {
				return nil, fmt.Errorf("API error: %v", errorDetail["message"])
			}
		}
		return nil, fmt.Errorf("API error (status %d): %s", resp.StatusCode, string(respBody))
	}

	// Parse successful response
	var result map[string]interface{}
	if err := json.Unmarshal(respBody, &result); err != nil {
		return nil, fmt.Errorf("failed to parse response: %w", err)
	}

	return result, nil
}

// Clone creates a copy of the node
func (n *AnthropicNode) Clone() base.Node {
	return &AnthropicNode{
		BaseNode:   n.BaseNode.Clone(),
		httpClient: n.httpClient,
	}
}