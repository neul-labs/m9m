package ai

import (
	"bytes"
	"encoding/json"
	"fmt"
	"io/ioutil"
	"net/http"
	"os"
	"strings"
	"time"

	"github.com/dipankar/n8n-go/internal/expressions"
	"github.com/dipankar/n8n-go/internal/nodes/base"
	"github.com/dipankar/n8n-go/internal/model"
)

// LiteLLMNode provides unified access to multiple LLM providers
type LiteLLMNode struct {
	*base.BaseNode
	evaluator    *expressions.GojaExpressionEvaluator
	httpClient   *http.Client
	credentials  map[string]string
}

type LiteLLMConfig struct {
	Provider        string                 `json:"provider"`
	Model           string                 `json:"model"`
	Messages        []Message              `json:"messages"`
	Temperature     float64                `json:"temperature"`
	MaxTokens       int                    `json:"max_tokens"`
	TopP            float64                `json:"top_p"`
	Stream          bool                   `json:"stream"`
	SystemMessage   string                 `json:"system_message"`
	ResponseFormat  string                 `json:"response_format"` // "text", "json", "markdown"
	Tools           []Tool                 `json:"tools"`
	ToolChoice      string                 `json:"tool_choice"`
	CustomEndpoint  string                 `json:"custom_endpoint"`
	APIKey          string                 `json:"api_key"`
	AdditionalParams map[string]interface{} `json:"additional_params"`
}

type Message struct {
	Role    string      `json:"role"`    // "system", "user", "assistant", "tool"
	Content interface{} `json:"content"` // string or array for multimodal
	Name    string      `json:"name,omitempty"`
	ToolCalls []ToolCall `json:"tool_calls,omitempty"`
	ToolCallID string    `json:"tool_call_id,omitempty"`
}

type Tool struct {
	Type     string         `json:"type"` // "function"
	Function ToolFunction   `json:"function"`
}

type ToolFunction struct {
	Name        string                 `json:"name"`
	Description string                 `json:"description"`
	Parameters  map[string]interface{} `json:"parameters"`
}

type ToolCall struct {
	ID       string       `json:"id"`
	Type     string       `json:"type"`
	Function FunctionCall `json:"function"`
}

type FunctionCall struct {
	Name      string `json:"name"`
	Arguments string `json:"arguments"`
}

type LiteLLMResponse struct {
	ID      string   `json:"id"`
	Object  string   `json:"object"`
	Created int64    `json:"created"`
	Model   string   `json:"model"`
	Choices []Choice `json:"choices"`
	Usage   Usage    `json:"usage"`
	Error   *Error   `json:"error,omitempty"`
}

type Choice struct {
	Index        int       `json:"index"`
	Message      Message   `json:"message"`
	FinishReason string    `json:"finish_reason"`
	LogProbs     *LogProbs `json:"logprobs,omitempty"`
}

type Usage struct {
	PromptTokens     int `json:"prompt_tokens"`
	CompletionTokens int `json:"completion_tokens"`
	TotalTokens      int `json:"total_tokens"`
}

type LogProbs struct {
	Content []TokenLogProb `json:"content"`
}

type TokenLogProb struct {
	Token   string  `json:"token"`
	LogProb float64 `json:"logprob"`
}

type Error struct {
	Message string `json:"message"`
	Type    string `json:"type"`
	Code    string `json:"code"`
}

// Provider configurations
var providerEndpoints = map[string]string{
	"openai":          "https://api.openai.com/v1/chat/completions",
	"anthropic":       "https://api.anthropic.com/v1/messages",
	"google-gemini":   "https://generativelanguage.googleapis.com/v1beta/models/%s:generateContent",
	"azure-openai":    "https://%s.openai.azure.com/openai/deployments/%s/chat/completions?api-version=2023-12-01-preview",
	"groq":            "https://api.groq.com/openai/v1/chat/completions",
	"mistral":         "https://api.mistral.ai/v1/chat/completions",
	"cohere":          "https://api.cohere.ai/v1/chat",
	"deepseek":        "https://api.deepseek.com/v1/chat/completions",
	"ollama":          "http://localhost:11434/api/chat",
	"litellm-proxy":   "http://localhost:4000/chat/completions",
}

// Model mappings
var modelMappings = map[string]string{
	// OpenAI
	"gpt-4":           "openai/gpt-4",
	"gpt-4-turbo":     "openai/gpt-4-turbo-preview",
	"gpt-3.5-turbo":   "openai/gpt-3.5-turbo",
	"gpt-4o":          "openai/gpt-4o",
	"gpt-4o-mini":     "openai/gpt-4o-mini",

	// Anthropic
	"claude-3-opus":    "anthropic/claude-3-opus-20240229",
	"claude-3-sonnet":  "anthropic/claude-3-sonnet-20240229",
	"claude-3-haiku":   "anthropic/claude-3-haiku-20240307",
	"claude-2.1":       "anthropic/claude-2.1",

	// Google
	"gemini-pro":       "google/gemini-pro",
	"gemini-pro-vision": "google/gemini-pro-vision",
	"gemini-1.5-pro":   "google/gemini-1.5-pro",
	"gemini-1.5-flash": "google/gemini-1.5-flash",

	// Mistral
	"mistral-large":    "mistral/mistral-large-latest",
	"mistral-medium":   "mistral/mistral-medium-latest",
	"mixtral-8x7b":     "mistral/mixtral-8x7b-instruct",

	// Groq
	"llama3-70b":       "groq/llama3-70b-8192",
	"llama3-8b":        "groq/llama3-8b-8192",
	"mixtral-groq":     "groq/mixtral-8x7b-32768",

	// Cohere
	"command-r-plus":   "cohere/command-r-plus",
	"command-r":        "cohere/command-r",
}

func NewLiteLLMNode() *LiteLLMNode {
	return &LiteLLMNode{
		BaseNode: base.NewBaseNode("LiteLLM", "Universal LLM interface", "1.0.0"),
		evaluator: expressions.NewGojaExpressionEvaluator(),
		httpClient: &http.Client{
			Timeout: 120 * time.Second, // Longer timeout for LLMs
		},
		credentials: make(map[string]string),
	}
}

func (n *LiteLLMNode) Execute(input *model.NodeExecutionInput) (*model.NodeExecutionOutput, error) {
	var config LiteLLMConfig
	if err := json.Unmarshal(input.Config, &config); err != nil {
		return nil, fmt.Errorf("failed to parse LiteLLM config: %w", err)
	}

	// Load credentials
	n.loadCredentials(config.Provider)

	var results []model.DataItem

	for i, item := range input.Items {
		// Process any expressions in the configuration
		processedConfig := n.processExpressions(config, item, i)

		// Make the LLM request
		response, err := n.callLLM(processedConfig)
		if err != nil {
			return &model.NodeExecutionOutput{
				Items: results,
				Error: fmt.Sprintf("LLM request failed: %s", err.Error()),
			}, nil
		}

		// Process the response
		result := n.processResponse(response, processedConfig)
		results = append(results, result)
	}

	return &model.NodeExecutionOutput{
		Items: results,
	}, nil
}

func (n *LiteLLMNode) loadCredentials(provider string) {
	// Load API keys from environment or credential store
	envVarMap := map[string]string{
		"openai":        "OPENAI_API_KEY",
		"anthropic":     "ANTHROPIC_API_KEY",
		"google-gemini": "GOOGLE_API_KEY",
		"azure-openai":  "AZURE_OPENAI_API_KEY",
		"groq":          "GROQ_API_KEY",
		"mistral":       "MISTRAL_API_KEY",
		"cohere":        "COHERE_API_KEY",
		"deepseek":      "DEEPSEEK_API_KEY",
	}

	if envVar, exists := envVarMap[provider]; exists {
		if apiKey := os.Getenv(envVar); apiKey != "" {
			n.credentials[provider] = apiKey
		}
	}
}

func (n *LiteLLMNode) processExpressions(config LiteLLMConfig, item model.DataItem, index int) LiteLLMConfig {
	context := expressions.NewExpressionContext()
	context.SetVariable("item", item.JSON)
	context.SetVariable("index", index)

	// Process messages
	for i, msg := range config.Messages {
		if content, ok := msg.Content.(string); ok {
			if processed, err := n.evaluator.EvaluateTemplateString(content, context); err == nil {
				config.Messages[i].Content = processed
			}
		}
	}

	// Process system message
	if config.SystemMessage != "" {
		if processed, err := n.evaluator.EvaluateTemplateString(config.SystemMessage, context); err == nil {
			config.SystemMessage = processed
		}
	}

	return config
}

func (n *LiteLLMNode) callLLM(config LiteLLMConfig) (*LiteLLMResponse, error) {
	// Build the request based on provider
	requestBody, err := n.buildRequest(config)
	if err != nil {
		return nil, err
	}

	// Get the endpoint
	endpoint := n.getEndpoint(config)

	// Create HTTP request
	req, err := http.NewRequest("POST", endpoint, bytes.NewBuffer(requestBody))
	if err != nil {
		return nil, err
	}

	// Set headers
	n.setHeaders(req, config)

	// Make the request
	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	// Read response
	body, err := ioutil.ReadAll(resp.Body)
	if err != nil {
		return nil, err
	}

	// Parse response based on provider
	return n.parseResponse(body, config.Provider)
}

func (n *LiteLLMNode) buildRequest(config LiteLLMConfig) ([]byte, error) {
	// Build unified request format
	request := map[string]interface{}{
		"model":       n.getModelName(config),
		"messages":    n.formatMessages(config),
		"temperature": config.Temperature,
		"max_tokens":  config.MaxTokens,
		"top_p":       config.TopP,
		"stream":      config.Stream,
	}

	// Add tools if specified
	if len(config.Tools) > 0 {
		request["tools"] = config.Tools
		if config.ToolChoice != "" {
			request["tool_choice"] = config.ToolChoice
		}
	}

	// Add response format if specified
	if config.ResponseFormat == "json" {
		request["response_format"] = map[string]string{"type": "json_object"}
	}

	// Provider-specific adjustments
	switch config.Provider {
	case "anthropic":
		request = n.convertToAnthropicFormat(request, config)
	case "google-gemini":
		request = n.convertToGeminiFormat(request, config)
	case "cohere":
		request = n.convertToCohereFormat(request, config)
	}

	// Add additional parameters
	for key, value := range config.AdditionalParams {
		request[key] = value
	}

	return json.Marshal(request)
}

func (n *LiteLLMNode) formatMessages(config LiteLLMConfig) []Message {
	messages := []Message{}

	// Add system message if present
	if config.SystemMessage != "" {
		messages = append(messages, Message{
			Role:    "system",
			Content: config.SystemMessage,
		})
	}

	// Add user messages
	messages = append(messages, config.Messages...)

	return messages
}

func (n *LiteLLMNode) getModelName(config LiteLLMConfig) string {
	// Check if model is already in provider/model format
	if strings.Contains(config.Model, "/") {
		return config.Model
	}

	// Look up model mapping
	if mapped, exists := modelMappings[config.Model]; exists {
		return mapped
	}

	// Default to provider/model format
	return fmt.Sprintf("%s/%s", config.Provider, config.Model)
}

func (n *LiteLLMNode) getEndpoint(config LiteLLMConfig) string {
	if config.CustomEndpoint != "" {
		return config.CustomEndpoint
	}

	if endpoint, exists := providerEndpoints[config.Provider]; exists {
		// Handle special cases
		switch config.Provider {
		case "google-gemini":
			return fmt.Sprintf(endpoint, config.Model)
		case "azure-openai":
			// Would need resource name and deployment name from config
			return endpoint
		default:
			return endpoint
		}
	}

	// Default to OpenAI-compatible endpoint
	return "https://api.openai.com/v1/chat/completions"
}

func (n *LiteLLMNode) setHeaders(req *http.Request, config LiteLLMConfig) {
	req.Header.Set("Content-Type", "application/json")

	// Get API key
	apiKey := config.APIKey
	if apiKey == "" {
		apiKey = n.credentials[config.Provider]
	}

	// Set authorization header based on provider
	switch config.Provider {
	case "anthropic":
		req.Header.Set("x-api-key", apiKey)
		req.Header.Set("anthropic-version", "2023-06-01")
	case "google-gemini":
		// API key is usually in URL for Gemini
		if apiKey != "" {
			req.URL.Query().Add("key", apiKey)
		}
	default:
		// Most providers use Bearer token
		if apiKey != "" {
			req.Header.Set("Authorization", "Bearer "+apiKey)
		}
	}
}

func (n *LiteLLMNode) parseResponse(body []byte, provider string) (*LiteLLMResponse, error) {
	var response LiteLLMResponse

	switch provider {
	case "anthropic":
		// Parse Anthropic-specific response format
		var anthropicResp map[string]interface{}
		if err := json.Unmarshal(body, &anthropicResp); err != nil {
			return nil, err
		}
		response = n.convertAnthropicResponse(anthropicResp)

	case "google-gemini":
		// Parse Gemini-specific response format
		var geminiResp map[string]interface{}
		if err := json.Unmarshal(body, &geminiResp); err != nil {
			return nil, err
		}
		response = n.convertGeminiResponse(geminiResp)

	default:
		// OpenAI-compatible format
		if err := json.Unmarshal(body, &response); err != nil {
			return nil, err
		}
	}

	// Check for errors
	if response.Error != nil {
		return nil, fmt.Errorf("%s: %s", response.Error.Type, response.Error.Message)
	}

	return &response, nil
}

func (n *LiteLLMNode) processResponse(response *LiteLLMResponse, config LiteLLMConfig) model.DataItem {
	result := map[string]interface{}{
		"model":   response.Model,
		"created": response.Created,
		"usage":   response.Usage,
	}

	// Extract the main content
	if len(response.Choices) > 0 {
		choice := response.Choices[0]
		result["content"] = choice.Message.Content
		result["role"] = choice.Message.Role
		result["finish_reason"] = choice.FinishReason

		// Handle tool calls
		if len(choice.Message.ToolCalls) > 0 {
			result["tool_calls"] = choice.Message.ToolCalls
		}
	}

	// Format based on response format
	switch config.ResponseFormat {
	case "json":
		// Try to parse content as JSON
		if content, ok := result["content"].(string); ok {
			var jsonContent interface{}
			if err := json.Unmarshal([]byte(content), &jsonContent); err == nil {
				result["parsed_content"] = jsonContent
			}
		}
	case "markdown":
		// Content is already in markdown format
		result["format"] = "markdown"
	default:
		result["format"] = "text"
	}

	return model.DataItem{JSON: result}
}

// Provider-specific format converters

func (n *LiteLLMNode) convertToAnthropicFormat(request map[string]interface{}, config LiteLLMConfig) map[string]interface{} {
	// Anthropic uses a different format
	anthropicRequest := map[string]interface{}{
		"model":       config.Model,
		"messages":    request["messages"],
		"max_tokens":  request["max_tokens"],
		"temperature": request["temperature"],
	}

	// Handle system message differently for Anthropic
	if messages, ok := request["messages"].([]Message); ok {
		var system string
		var nonSystemMessages []Message

		for _, msg := range messages {
			if msg.Role == "system" {
				system = msg.Content.(string)
			} else {
				nonSystemMessages = append(nonSystemMessages, msg)
			}
		}

		if system != "" {
			anthropicRequest["system"] = system
		}
		anthropicRequest["messages"] = nonSystemMessages
	}

	return anthropicRequest
}

func (n *LiteLLMNode) convertToGeminiFormat(request map[string]interface{}, config LiteLLMConfig) map[string]interface{} {
	// Google Gemini uses a different format
	geminiRequest := map[string]interface{}{
		"contents": n.convertMessagesToGeminiFormat(request["messages"]),
		"generationConfig": map[string]interface{}{
			"temperature":     request["temperature"],
			"maxOutputTokens": request["max_tokens"],
			"topP":            request["top_p"],
		},
	}

	return geminiRequest
}

func (n *LiteLLMNode) convertToCohereFormat(request map[string]interface{}, config LiteLLMConfig) map[string]interface{} {
	// Cohere uses a different format
	cohereRequest := map[string]interface{}{
		"model":       config.Model,
		"message":     n.getLastUserMessage(request["messages"]),
		"temperature": request["temperature"],
		"max_tokens":  request["max_tokens"],
	}

	// Add chat history
	if messages, ok := request["messages"].([]Message); ok && len(messages) > 1 {
		cohereRequest["chat_history"] = messages[:len(messages)-1]
	}

	return cohereRequest
}

func (n *LiteLLMNode) convertMessagesToGeminiFormat(messages interface{}) []map[string]interface{} {
	geminiMessages := []map[string]interface{}{}

	if msgs, ok := messages.([]Message); ok {
		for _, msg := range msgs {
			geminiMessage := map[string]interface{}{
				"role": n.mapRoleToGemini(msg.Role),
				"parts": []map[string]interface{}{
					{"text": msg.Content},
				},
			}
			geminiMessages = append(geminiMessages, geminiMessage)
		}
	}

	return geminiMessages
}

func (n *LiteLLMNode) mapRoleToGemini(role string) string {
	switch role {
	case "assistant":
		return "model"
	case "system":
		return "user" // Gemini doesn't have system role
	default:
		return role
	}
}

func (n *LiteLLMNode) getLastUserMessage(messages interface{}) string {
	if msgs, ok := messages.([]Message); ok {
		for i := len(msgs) - 1; i >= 0; i-- {
			if msgs[i].Role == "user" {
				if content, ok := msgs[i].Content.(string); ok {
					return content
				}
			}
		}
	}
	return ""
}

func (n *LiteLLMNode) convertAnthropicResponse(resp map[string]interface{}) LiteLLMResponse {
	// Convert Anthropic response to standard format
	response := LiteLLMResponse{
		Model:   resp["model"].(string),
		Created: time.Now().Unix(),
	}

	if content, exists := resp["content"]; exists {
		if contentArray, ok := content.([]interface{}); ok && len(contentArray) > 0 {
			if firstContent, ok := contentArray[0].(map[string]interface{}); ok {
				response.Choices = []Choice{
					{
						Message: Message{
							Role:    "assistant",
							Content: firstContent["text"],
						},
						FinishReason: resp["stop_reason"].(string),
					},
				}
			}
		}
	}

	if usage, exists := resp["usage"]; exists {
		if usageMap, ok := usage.(map[string]interface{}); ok {
			response.Usage = Usage{
				PromptTokens:     int(usageMap["input_tokens"].(float64)),
				CompletionTokens: int(usageMap["output_tokens"].(float64)),
			}
			response.Usage.TotalTokens = response.Usage.PromptTokens + response.Usage.CompletionTokens
		}
	}

	return response
}

func (n *LiteLLMNode) convertGeminiResponse(resp map[string]interface{}) LiteLLMResponse {
	// Convert Gemini response to standard format
	response := LiteLLMResponse{
		Model:   "gemini",
		Created: time.Now().Unix(),
	}

	if candidates, exists := resp["candidates"]; exists {
		if candidateArray, ok := candidates.([]interface{}); ok && len(candidateArray) > 0 {
			if candidate, ok := candidateArray[0].(map[string]interface{}); ok {
				if content, exists := candidate["content"]; exists {
					if contentMap, ok := content.(map[string]interface{}); ok {
						if parts, exists := contentMap["parts"]; exists {
							if partsArray, ok := parts.([]interface{}); ok && len(partsArray) > 0 {
								if part, ok := partsArray[0].(map[string]interface{}); ok {
									response.Choices = []Choice{
										{
											Message: Message{
												Role:    "assistant",
												Content: part["text"],
											},
											FinishReason: n.getGeminiFinishReason(candidate),
										},
									}
								}
							}
						}
					}
				}
			}
		}
	}

	// Gemini doesn't provide token counts in the same way
	response.Usage = Usage{
		TotalTokens: -1, // Indicate unknown
	}

	return response
}

func (n *LiteLLMNode) getGeminiFinishReason(candidate map[string]interface{}) string {
	if finishReason, exists := candidate["finishReason"]; exists {
		return finishReason.(string)
	}
	return "stop"
}

func (n *LiteLLMNode) GetNodeDefinition() *model.NodeDefinition {
	return &model.NodeDefinition{
		Name:        "LiteLLM",
		DisplayName: "LiteLLM - Universal LLM",
		Description: "Access multiple LLM providers through a unified interface",
		Version:     "1.0.0",
		Category:    "ai",
		Icon:        "ai",
		Color:       "#FF6B6B",
		Properties: []model.NodeProperty{
			{
				Name:        "provider",
				DisplayName: "Provider",
				Type:        "select",
				Required:    true,
				Default:     "openai",
				Options: []model.NodePropertyOption{
					{Name: "OpenAI", Value: "openai"},
					{Name: "Anthropic (Claude)", Value: "anthropic"},
					{Name: "Google Gemini", Value: "google-gemini"},
					{Name: "Azure OpenAI", Value: "azure-openai"},
					{Name: "Groq", Value: "groq"},
					{Name: "Mistral", Value: "mistral"},
					{Name: "Cohere", Value: "cohere"},
					{Name: "DeepSeek", Value: "deepseek"},
					{Name: "Ollama (Local)", Value: "ollama"},
					{Name: "LiteLLM Proxy", Value: "litellm-proxy"},
				},
				Description: "LLM provider to use",
			},
			{
				Name:        "model",
				DisplayName: "Model",
				Type:        "string",
				Required:    true,
				Default:     "gpt-3.5-turbo",
				Description: "Model to use (e.g., gpt-4, claude-3-opus, gemini-pro)",
			},
			{
				Name:        "messages",
				DisplayName: "Messages",
				Type:        "json",
				Required:    true,
				Default: []Message{
					{Role: "user", Content: "Hello, how can you help me?"},
				},
				Description: "Messages to send to the LLM",
			},
			{
				Name:        "systemMessage",
				DisplayName: "System Message",
				Type:        "string",
				Required:    false,
				Description: "System message to set context",
			},
			{
				Name:        "temperature",
				DisplayName: "Temperature",
				Type:        "number",
				Required:    false,
				Default:     0.7,
				Description: "Controls randomness (0.0 to 2.0)",
			},
			{
				Name:        "maxTokens",
				DisplayName: "Max Tokens",
				Type:        "number",
				Required:    false,
				Default:     1000,
				Description: "Maximum number of tokens to generate",
			},
			{
				Name:        "responseFormat",
				DisplayName: "Response Format",
				Type:        "select",
				Required:    false,
				Default:     "text",
				Options: []model.NodePropertyOption{
					{Name: "Text", Value: "text"},
					{Name: "JSON", Value: "json"},
					{Name: "Markdown", Value: "markdown"},
				},
				Description: "Format of the response",
			},
		},
		Inputs:  []string{"main"},
		Outputs: []string{"main"},
	}
}