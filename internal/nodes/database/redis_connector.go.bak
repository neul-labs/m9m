// Hash operations

func (n *RedisConnectorNode) executeHashGet(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	field, err := n.evaluateStringParam(nodeParams, "field", context)
	if err != nil {
		return nil, err
	}

	value, err := n.client.HGet(context.TODO(), key, field).Result()
	if err != nil && err != redis.Nil {
		return nil, fmt.Errorf("HGET operation failed: %w", err)
	}

	var resultValue interface{}
	if err != redis.Nil {
		resultValue = value
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         resultValue,
		ExecutionTime: time.Since(startTime),
		Operation:     "hget",
	}, nil
}

func (n *RedisConnectorNode) executeHashSet(item model.DataItem, nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	field, err := n.evaluateStringParam(nodeParams, "field", context)
	if err != nil {
		return nil, err
	}

	value, err := n.evaluateValue(item, nodeParams, context)
	if err != nil {
		return nil, err
	}

	// Convert value to string
	var valueStr string
	switch v := value.(type) {
	case string:
		valueStr = v
	default:
		jsonBytes, err := json.Marshal(v)
		if err != nil {
			return nil, fmt.Errorf("failed to encode value: %w", err)
		}
		valueStr = string(jsonBytes)
	}

	created, err := n.client.HSet(context.TODO(), key, field, valueStr).Result()
	if err != nil {
		return nil, fmt.Errorf("HSET operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         created,
		ExecutionTime: time.Since(startTime),
		Operation:     "hset",
	}, nil
}

func (n *RedisConnectorNode) executeHashDelete(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	field, err := n.evaluateStringParam(nodeParams, "field", context)
	if err != nil {
		return nil, err
	}

	deleted, err := n.client.HDel(context.TODO(), key, field).Result()
	if err != nil {
		return nil, fmt.Errorf("HDEL operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         deleted,
		ExecutionTime: time.Since(startTime),
		Operation:     "hdel",
	}, nil
}

func (n *RedisConnectorNode) executeHashGetAll(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	hash, err := n.client.HGetAll(context.TODO(), key).Result()
	if err != nil {
		return nil, fmt.Errorf("HGETALL operation failed: %w", err)
	}

	// Convert to map[string]interface{}
	result := make(map[string]interface{})
	for k, v := range hash {
		result[k] = v
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         result,
		ExecutionTime: time.Since(startTime),
		Operation:     "hgetall",
	}, nil
}

// General operations

func (n *RedisConnectorNode) executeKeys(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	pattern, err := n.evaluateStringParam(nodeParams, "pattern", context)
	if err != nil {
		return nil, err
	}

	if pattern == "" {
		pattern = "*" // Default to all keys
	}

	keys, err := n.client.Keys(context.TODO(), pattern).Result()
	if err != nil {
		return nil, fmt.Errorf("KEYS operation failed: %w", err)
	}

	// Convert to interface slice
	result := make([]interface{}, len(keys))
	for i, v := range keys {
		result[i] = v
	}

	return &RedisResult{
		Success:       true,
		Values:        result,
		ExecutionTime: time.Since(startTime),
		Operation:     "keys",
	}, nil
}

func (n *RedisConnectorNode) executeFlushDB(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	err := n.client.FlushDB(context.TODO()).Err()
	if err != nil {
		return nil, fmt.Errorf("FLUSHDB operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		ExecutionTime: time.Since(startTime),
		Operation:     "flushdb",
	}, nil
}

func (n *RedisConnectorNode) executePing() (*RedisResult, error) {
	startTime := time.Now()

	pong, err := n.client.Ping(context.TODO()).Result()
	if err != nil {
		return nil, fmt.Errorf("PING operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		Value:         pong,
		ExecutionTime: time.Since(startTime),
		Operation:     "ping",
	}, nil
}

// Helper methods

func (n *RedisConnectorNode) evaluateKey(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (string, error) {
	keyExpr, ok := nodeParams["key"].(string)
	if !ok {
		return "", fmt.Errorf("key parameter is required")
	}

	key, err := n.evaluator.EvaluateExpression(keyExpr, context)
	if err != nil {
		return "", fmt.Errorf("failed to evaluate key: %w", err)
	}

	keyStr, ok := key.(string)
	if !ok {
		return "", fmt.Errorf("key must be a string")
	}

	return keyStr, nil
}

func (n *RedisConnectorNode) evaluateKeys(nodeParams map[string]interface{}, context *expressions.ExpressionContext) ([]string, error) {
	keysExpr, ok := nodeParams["keys"].(string)
	if !ok {
		return nil, fmt.Errorf("keys parameter is required")
	}

	keys, err := n.evaluator.EvaluateExpression(keysExpr, context)
	if err != nil {
		return nil, fmt.Errorf("failed to evaluate keys: %w", err)
	}

	if keySlice, ok := keys.([]interface{}); ok {
		result := make([]string, len(keySlice))
		for i, k := range keySlice {
			if keyStr, ok := k.(string); ok {
				result[i] = keyStr
			} else {
				return nil, fmt.Errorf("all keys must be strings")
			}
		}
		return result, nil
	}

	return nil, fmt.Errorf("keys must be an array of strings")
}

func (n *RedisConnectorNode) evaluateValue(item model.DataItem, nodeParams map[string]interface{}, context *expressions.ExpressionContext) (interface{}, error) {
	if valueExpr, ok := nodeParams["value"].(string); ok {
		return n.evaluator.EvaluateExpression(valueExpr, context)
	}

	// Default to using the first value from item JSON
	for _, value := range item.JSON {
		return value, nil
	}

	return nil, fmt.Errorf("no value found")
}

func (n *RedisConnectorNode) evaluateStringParam(nodeParams map[string]interface{}, paramName string, context *expressions.ExpressionContext) (string, error) {
	paramExpr, ok := nodeParams[paramName].(string)
	if !ok {
		return "", fmt.Errorf("%s parameter is required", paramName)
	}

	param, err := n.evaluator.EvaluateExpression(paramExpr, context)
	if err != nil {
		return "", fmt.Errorf("failed to evaluate %s: %w", paramName, err)
	}

	paramStr, ok := param.(string)
	if !ok {
		return "", fmt.Errorf("%s must be a string", paramName)
	}

	return paramStr, nil
}

// Connection management

func (n *RedisConnectorNode) connect(config *RedisConfig) error {
	// Close existing connection if any
	if n.client != nil {
		n.client.Close()
	}

	// Create Redis options
	opts := &redis.Options{
		Addr:     fmt.Sprintf("%s:%d", config.Host, config.Port),
		Password: config.Password,
		DB:       config.Database,
	}

	// Configure TLS if enabled
	if config.TLS {
		opts.TLSConfig = &tls.Config{
			ServerName: config.Host,
		}
	}

	// Create client
	client := redis.NewClient(opts)

	// Test connection
	_, err := client.Ping(context.TODO()).Result()
	if err != nil {
		return fmt.Errorf("failed to ping Redis: %w", err)
	}

	n.client = client
	n.config = config

	return nil
}

func (n *RedisConnectorNode) parseRedisConfig(nodeParams map[string]interface{}) (*RedisConfig, error) {
	config := &RedisConfig{
		Host:     "localhost",
		Port:     6379,
		Database: 0,
		Options:  make(map[string]string),
	}

	if host, ok := nodeParams["host"].(string); ok {
		config.Host = host
	}

	if port, ok := nodeParams["port"]; ok {
		if portInt, ok := port.(int); ok {
			config.Port = portInt
		} else if portStr, ok := port.(string); ok {
			if portParsed, err := strconv.Atoi(portStr); err == nil {
				config.Port = portParsed
			}
		}
	}

	if password, ok := nodeParams["password"].(string); ok {
		config.Password = password
	}

	if database, ok := nodeParams["database"]; ok {
		if dbInt, ok := database.(int); ok {
			config.Database = dbInt
		} else if dbStr, ok := database.(string); ok {
			if dbParsed, err := strconv.Atoi(dbStr); err == nil {
				config.Database = dbParsed
			}
		}
	}

	if tls, ok := nodeParams["tls"].(bool); ok {
		config.TLS = tls
	}

	return config, nil
}

func (n *RedisConnectorNode) isSameConfig(config *RedisConfig) bool {
	if n.config == nil {
		return false
	}

	return n.config.Host == config.Host &&
		n.config.Port == config.Port &&
		n.config.Password == config.Password &&
		n.config.Database == config.Database &&
		n.config.TLS == config.TLS
}

// ValidateParameters validates the node parameters
func (n *RedisConnectorNode) ValidateParameters(params map[string]interface{}) error {
	// Validate Redis configuration
	_, err := n.parseRedisConfig(params)
	if err != nil {
		return fmt.Errorf("invalid Redis configuration: %w", err)
	}

	// Validate operation
	operation, _ := params["operation"].(string)
	validOperations := []string{
		"get", "set", "del", "delete", "exists", "expire", "ttl",
		"incr", "increment", "decr", "decrement", "mget", "mset",
		"lpush", "rpush", "lpop", "rpop", "llen", "lrange",
		"sadd", "srem", "smembers", "scard",
		"hget", "hset", "hdel", "hgetall",
		"keys", "flushdb", "ping",
	}

	if operation != "" {
		valid := false
		for _, validOp := range validOperations {
			if operation == validOp {
				valid = true
				break
			}
		}
		if !valid {
			return fmt.Errorf("invalid operation: %s. Valid operations: %v", operation, validOperations)
		}
	}

	return nil
}

// Close closes the Redis connection
func (n *RedisConnectorNode) Close() error {
	if n.client != nil {
		return n.client.Close()
	}
	return nil
}