package database

import (
	"context"
	"crypto/tls"
	"encoding/json"
	"fmt"
	"strconv"
	"strings"
	"time"

	"github.com/redis/go-redis/v9"

	"github.com/dipankar/n8n-go/internal/expressions"
	"github.com/dipankar/n8n-go/internal/model"
	"github.com/dipankar/n8n-go/internal/nodes/base"
)

// RedisConnectorNode provides Redis database connectivity
type RedisConnectorNode struct {
	*base.BaseNode
	evaluator *expressions.GojaExpressionEvaluator
	client    *redis.Client
	config    *RedisConfig
}

// RedisConfig holds Redis connection configuration
type RedisConfig struct {
	Host     string `json:"host"`
	Port     int    `json:"port"`
	Password string `json:"password,omitempty"`
	Database int    `json:"database"`
	TLS      bool   `json:"tls"`
	Options  map[string]string `json:"options,omitempty"`
}

// RedisResult represents the result of a Redis operation
type RedisResult struct {
	Value         interface{}   `json:"value,omitempty"`
	Values        []interface{} `json:"values,omitempty"`
	Success       bool          `json:"success"`
	AffectedKeys  int           `json:"affectedKeys,omitempty"`
	ExecutionTime time.Duration `json:"executionTime"`
	Operation     string        `json:"operation"`
	Key           string        `json:"key,omitempty"`
	TTL           time.Duration `json:"ttl,omitempty"`
}

// NewRedisConnectorNode creates a new Redis connector node
func NewRedisConnectorNode() *RedisConnectorNode {
	return &RedisConnectorNode{
		BaseNode:  base.NewBaseNode("Redis", "n8n-nodes-base.redis"),
		evaluator: expressions.NewGojaExpressionEvaluator(),
	}
}

// Execute performs Redis operations based on the operation type
func (n *RedisConnectorNode) Execute(inputData []model.DataItem, nodeParams map[string]interface{}) ([]model.DataItem, error) {
	var results []model.DataItem

	// Get Redis configuration
	config, err := n.parseRedisConfig(nodeParams)
	if err != nil {
		return nil, n.CreateError("invalid Redis configuration", map[string]interface{}{
			"error": err.Error(),
		})
	}

	// Connect to Redis if not already connected
	if n.client == nil || n.config == nil || !n.isSameConfig(config) {
		if err := n.connect(config); err != nil {
			return nil, n.CreateError("failed to connect to Redis", map[string]interface{}{
				"error": err.Error(),
			})
		}
	}

	// Get operation type
	operation, _ := nodeParams["operation"].(string)
	if operation == "" {
		operation = "get" // Default operation
	}

	for index, item := range inputData {
		// Create expression context
		context := &expressions.ExpressionContext{
			ActiveNodeName:      "Redis",
			RunIndex:           0,
			ItemIndex:          index,
			Mode:               expressions.ModeManual,
			ConnectionInputData: []model.DataItem{item},
			AdditionalKeys:     make(map[string]interface{}),
		}

		var result *RedisResult
		switch strings.ToLower(operation) {
		case "get":
			result, err = n.executeGet(nodeParams, context)
		case "set":
			result, err = n.executeSet(item, nodeParams, context)
		case "del", "delete":
			result, err = n.executeDelete(nodeParams, context)
		case "exists":
			result, err = n.executeExists(nodeParams, context)
		case "expire":
			result, err = n.executeExpire(nodeParams, context)
		case "ttl":
			result, err = n.executeTTL(nodeParams, context)
		case "incr", "increment":
			result, err = n.executeIncrement(nodeParams, context)
		case "decr", "decrement":
			result, err = n.executeDecrement(nodeParams, context)
		case "mget":
			result, err = n.executeMultiGet(nodeParams, context)
		case "mset":
			result, err = n.executeMultiSet(item, nodeParams, context)
		case "lpush":
			result, err = n.executeListPush(item, nodeParams, context, "left")
		case "rpush":
			result, err = n.executeListPush(item, nodeParams, context, "right")
		case "lpop":
			result, err = n.executeListPop(nodeParams, context, "left")
		case "rpop":
			result, err = n.executeListPop(nodeParams, context, "right")
		case "llen":
			result, err = n.executeListLength(nodeParams, context)
		case "lrange":
			result, err = n.executeListRange(nodeParams, context)
		case "sadd":
			result, err = n.executeSetAdd(item, nodeParams, context)
		case "srem":
			result, err = n.executeSetRemove(nodeParams, context)
		case "smembers":
			result, err = n.executeSetMembers(nodeParams, context)
		case "scard":
			result, err = n.executeSetCard(nodeParams, context)
		case "hget":
			result, err = n.executeHashGet(nodeParams, context)
		case "hset":
			result, err = n.executeHashSet(item, nodeParams, context)
		case "hdel":
			result, err = n.executeHashDelete(nodeParams, context)
		case "hgetall":
			result, err = n.executeHashGetAll(nodeParams, context)
		case "keys":
			result, err = n.executeKeys(nodeParams, context)
		case "flushdb":
			result, err = n.executeFlushDB(nodeParams, context)
		case "ping":
			result, err = n.executePing()
		default:
			return nil, n.CreateError("unsupported operation", map[string]interface{}{
				"operation": operation,
			})
		}

		if err != nil {
			return nil, n.CreateError("Redis operation failed", map[string]interface{}{
				"operation": operation,
				"error":     err.Error(),
			})
		}

		// Create result item
		resultItem := model.DataItem{
			JSON: map[string]interface{}{
				"success":       result.Success,
				"operation":     result.Operation,
				"key":           result.Key,
				"value":         result.Value,
				"values":        result.Values,
				"affectedKeys":  result.AffectedKeys,
				"executionTime": result.ExecutionTime.String(),
				"ttl":           result.TTL.String(),
			},
		}

		results = append(results, resultItem)
	}

	return results, nil
}

// String operations

func (n *RedisConnectorNode) executeGet(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	val, err := n.client.Get(context.TODO(), key).Result()
	if err != nil && err != redis.Nil {
		return nil, fmt.Errorf("GET operation failed: %w", err)
	}

	var value interface{}
	if err != redis.Nil {
		value = val
	}

	return &RedisResult{
		Value:         value,
		Success:       true,
		Key:           key,
		ExecutionTime: time.Since(startTime),
		Operation:     "get",
	}, nil
}

func (n *RedisConnectorNode) executeSet(item model.DataItem, nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	value, err := n.evaluateValue(item, nodeParams, context)
	if err != nil {
		return nil, err
	}

	// Get TTL if specified
	var expiration time.Duration
	if ttl, ok := nodeParams["ttl"]; ok {
		if ttlInt, ok := ttl.(int); ok && ttlInt > 0 {
			expiration = time.Duration(ttlInt) * time.Second
		} else if ttlStr, ok := ttl.(string); ok {
			if ttlDuration, err := time.ParseDuration(ttlStr); err == nil {
				expiration = ttlDuration
			}
		}
	}

	// Convert value to string for Redis
	var valueStr string
	switch v := value.(type) {
	case string:
		valueStr = v
	case []byte:
		valueStr = string(v)
	default:
		// JSON encode complex types
		jsonBytes, err := json.Marshal(v)
		if err != nil {
			return nil, fmt.Errorf("failed to encode value: %w", err)
		}
		valueStr = string(jsonBytes)
	}

	err = n.client.Set(context.TODO(), key, valueStr, expiration).Err()
	if err != nil {
		return nil, fmt.Errorf("SET operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         value,
		ExecutionTime: time.Since(startTime),
		Operation:     "set",
	}, nil
}

func (n *RedisConnectorNode) executeDelete(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	deleted, err := n.client.Del(context.TODO(), key).Result()
	if err != nil {
		return nil, fmt.Errorf("DEL operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		AffectedKeys:  int(deleted),
		ExecutionTime: time.Since(startTime),
		Operation:     "delete",
	}, nil
}

func (n *RedisConnectorNode) executeExists(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	exists, err := n.client.Exists(context.TODO(), key).Result()
	if err != nil {
		return nil, fmt.Errorf("EXISTS operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         exists > 0,
		ExecutionTime: time.Since(startTime),
		Operation:     "exists",
	}, nil
}

func (n *RedisConnectorNode) executeExpire(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	// Get TTL
	var expiration time.Duration
	if ttl, ok := nodeParams["ttl"]; ok {
		if ttlInt, ok := ttl.(int); ok && ttlInt > 0 {
			expiration = time.Duration(ttlInt) * time.Second
		} else if ttlStr, ok := ttl.(string); ok {
			if ttlDuration, err := time.ParseDuration(ttlStr); err == nil {
				expiration = ttlDuration
			}
		}
	}

	if expiration == 0 {
		return nil, fmt.Errorf("ttl parameter is required for expire operation")
	}

	success, err := n.client.Expire(context.TODO(), key, expiration).Result()
	if err != nil {
		return nil, fmt.Errorf("EXPIRE operation failed: %w", err)
	}

	return &RedisResult{
		Success:       success,
		Key:           key,
		TTL:           expiration,
		ExecutionTime: time.Since(startTime),
		Operation:     "expire",
	}, nil
}

func (n *RedisConnectorNode) executeTTL(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	ttl, err := n.client.TTL(context.TODO(), key).Result()
	if err != nil {
		return nil, fmt.Errorf("TTL operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		TTL:           ttl,
		Value:         int64(ttl.Seconds()),
		ExecutionTime: time.Since(startTime),
		Operation:     "ttl",
	}, nil
}

func (n *RedisConnectorNode) executeIncrement(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	// Get increment value, default to 1
	increment := int64(1)
	if incr, ok := nodeParams["increment"]; ok {
		if incrInt, ok := incr.(int); ok {
			increment = int64(incrInt)
		} else if incrStr, ok := incr.(string); ok {
			if parsed, err := strconv.ParseInt(incrStr, 10, 64); err == nil {
				increment = parsed
			}
		}
	}

	var newValue int64
	var err2 error
	if increment == 1 {
		newValue, err2 = n.client.Incr(context.TODO(), key).Result()
	} else {
		newValue, err2 = n.client.IncrBy(context.TODO(), key, increment).Result()
	}

	if err2 != nil {
		return nil, fmt.Errorf("INCR operation failed: %w", err2)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         newValue,
		ExecutionTime: time.Since(startTime),
		Operation:     "increment",
	}, nil
}

func (n *RedisConnectorNode) executeDecrement(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	// Get decrement value, default to 1
	decrement := int64(1)
	if decr, ok := nodeParams["decrement"]; ok {
		if decrInt, ok := decr.(int); ok {
			decrement = int64(decrInt)
		} else if decrStr, ok := decr.(string); ok {
			if parsed, err := strconv.ParseInt(decrStr, 10, 64); err == nil {
				decrement = parsed
			}
		}
	}

	var newValue int64
	var err2 error
	if decrement == 1 {
		newValue, err2 = n.client.Decr(context.TODO(), key).Result()
	} else {
		newValue, err2 = n.client.DecrBy(context.TODO(), key, decrement).Result()
	}

	if err2 != nil {
		return nil, fmt.Errorf("DECR operation failed: %w", err2)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         newValue,
		ExecutionTime: time.Since(startTime),
		Operation:     "decrement",
	}, nil
}

// Multi-key operations

func (n *RedisConnectorNode) executeMultiGet(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	keys, err := n.evaluateKeys(nodeParams, context)
	if err != nil {
		return nil, err
	}

	values, err := n.client.MGet(context.TODO(), keys...).Result()
	if err != nil {
		return nil, fmt.Errorf("MGET operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		Values:        values,
		ExecutionTime: time.Since(startTime),
		Operation:     "mget",
	}, nil
}

func (n *RedisConnectorNode) executeMultiSet(item model.DataItem, nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	// Parse key-value pairs from item data or parameters
	var pairs []interface{}

	if mapping, ok := nodeParams["keyValueMapping"].(map[string]interface{}); ok {
		for key, valueExpr := range mapping {
			if valueExprStr, ok := valueExpr.(string); ok {
				value, err := n.evaluator.EvaluateExpression(valueExprStr, context)
				if err != nil {
					return nil, fmt.Errorf("failed to evaluate value for key %s: %w", key, err)
				}

				// Convert value to string
				var valueStr string
				switch v := value.(type) {
				case string:
					valueStr = v
				default:
					jsonBytes, err := json.Marshal(v)
					if err != nil {
						return nil, fmt.Errorf("failed to encode value for key %s: %w", key, err)
					}
					valueStr = string(jsonBytes)
				}

				pairs = append(pairs, key, valueStr)
			}
		}
	} else {
		// Use item JSON data
		for key, value := range item.JSON {
			var valueStr string
			switch v := value.(type) {
			case string:
				valueStr = v
			default:
				jsonBytes, err := json.Marshal(v)
				if err != nil {
					return nil, fmt.Errorf("failed to encode value for key %s: %w", key, err)
				}
				valueStr = string(jsonBytes)
			}
			pairs = append(pairs, key, valueStr)
		}
	}

	if len(pairs) == 0 {
		return nil, fmt.Errorf("no key-value pairs to set")
	}

	err := n.client.MSet(context.TODO(), pairs...).Err()
	if err != nil {
		return nil, fmt.Errorf("MSET operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		AffectedKeys:  len(pairs) / 2,
		ExecutionTime: time.Since(startTime),
		Operation:     "mset",
	}, nil
}

// List operations

func (n *RedisConnectorNode) executeListPush(item model.DataItem, nodeParams map[string]interface{}, context *expressions.ExpressionContext, direction string) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	value, err := n.evaluateValue(item, nodeParams, context)
	if err != nil {
		return nil, err
	}

	// Convert value to string
	var valueStr string
	switch v := value.(type) {
	case string:
		valueStr = v
	default:
		jsonBytes, err := json.Marshal(v)
		if err != nil {
			return nil, fmt.Errorf("failed to encode value: %w", err)
		}
		valueStr = string(jsonBytes)
	}

	var length int64
	if direction == "left" {
		length, err = n.client.LPush(context.TODO(), key, valueStr).Result()
	} else {
		length, err = n.client.RPush(context.TODO(), key, valueStr).Result()
	}

	if err != nil {
		return nil, fmt.Errorf("%sPUSH operation failed: %w", strings.ToUpper(direction[:1]), err)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         length,
		ExecutionTime: time.Since(startTime),
		Operation:     fmt.Sprintf("%spush", direction),
	}, nil
}

func (n *RedisConnectorNode) executeListPop(nodeParams map[string]interface{}, context *expressions.ExpressionContext, direction string) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	var value string
	var err2 error
	if direction == "left" {
		value, err2 = n.client.LPop(context.TODO(), key).Result()
	} else {
		value, err2 = n.client.RPop(context.TODO(), key).Result()
	}

	if err2 != nil && err2 != redis.Nil {
		return nil, fmt.Errorf("%sPOP operation failed: %w", strings.ToUpper(direction[:1]), err2)
	}

	var resultValue interface{}
	if err2 != redis.Nil {
		resultValue = value
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         resultValue,
		ExecutionTime: time.Since(startTime),
		Operation:     fmt.Sprintf("%spop", direction),
	}, nil
}

func (n *RedisConnectorNode) executeListLength(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	length, err := n.client.LLen(context.TODO(), key).Result()
	if err != nil {
		return nil, fmt.Errorf("LLEN operation failed: %w", err)
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Value:         length,
		ExecutionTime: time.Since(startTime),
		Operation:     "llen",
	}, nil
}

func (n *RedisConnectorNode) executeListRange(nodeParams map[string]interface{}, context *expressions.ExpressionContext) (*RedisResult, error) {
	startTime := time.Now()

	key, err := n.evaluateKey(nodeParams, context)
	if err != nil {
		return nil, err
	}

	// Get start and stop indices
	start := int64(0)
	stop := int64(-1) // Default to all elements

	if startParam, ok := nodeParams["start"]; ok {
		if startInt, ok := startParam.(int); ok {
			start = int64(startInt)
		}
	}

	if stopParam, ok := nodeParams["stop"]; ok {
		if stopInt, ok := stopParam.(int); ok {
			stop = int64(stopInt)
		}
	}

	values, err := n.client.LRange(context.TODO(), key, start, stop).Result()
	if err != nil {
		return nil, fmt.Errorf("LRANGE operation failed: %w", err)
	}

	// Convert to interface slice
	result := make([]interface{}, len(values))
	for i, v := range values {
		result[i] = v
	}

	return &RedisResult{
		Success:       true,
		Key:           key,
		Values:        result,
		ExecutionTime: time.Since(startTime),
		Operation:     "lrange",
	}, nil
}

