// Utility functions

func extractHeaders(r *http.Request) map[string]string {
	headers := make(map[string]string)
	for key, values := range r.Header {
		headers[key] = strings.Join(values, ", ")
	}
	return headers
}

func extractQueryParams(r *http.Request) map[string]string {
	params := make(map[string]string)
	for key, values := range r.URL.Query() {
		params[key] = strings.Join(values, ", ")
	}
	return params
}

func extractJSONPath(data interface{}, path string) interface{} {
	// Simplified JSON path extraction
	// In a real implementation, use a proper JSON path library
	if dataMap, ok := data.(map[string]interface{}); ok {
		if strings.Contains(path, ".") {
			parts := strings.SplitN(path, ".", 2)
			if value, exists := dataMap[parts[0]]; exists {
				return extractJSONPath(value, parts[1])
			}
		} else {
			return dataMap[path]
		}
	}
	return nil
}

func applyMapping(data interface{}, mapping map[string]interface{}) interface{} {
	// Simplified mapping application
	// In a real implementation, this would be more sophisticated
	if dataMap, ok := data.(map[string]interface{}); ok {
		result := make(map[string]interface{})
		for targetKey, sourceKey := range mapping {
			if sourceKeyStr, ok := sourceKey.(string); ok {
				result[targetKey] = dataMap[sourceKeyStr]
			}
		}
		return result
	}
	return data
}

func generateRequestID() string {
	// Generate a unique request ID
	return fmt.Sprintf("%d", time.Now().UnixNano())
}

// Rate limiter implementation

func NewRateLimiter(rate, capacity float64) *RateLimiter {
	return &RateLimiter{
		tokens:     capacity,
		capacity:   capacity,
		refillRate: rate,
		lastRefill: time.Now(),
	}
}

func (rl *RateLimiter) Allow() bool {
	rl.mu.Lock()
	defer rl.mu.Unlock()

	now := time.Now()
	elapsed := now.Sub(rl.lastRefill).Seconds()

	// Add tokens based on elapsed time
	rl.tokens += elapsed * rl.refillRate
	if rl.tokens > rl.capacity {
		rl.tokens = rl.capacity
	}

	rl.lastRefill = now

	// Check if we have tokens available
	if rl.tokens >= 1 {
		rl.tokens--
		return true
	}

	return false
}

// Analytics implementation

func NewWebhookAnalytics() *WebhookAnalytics {
	return &WebhookAnalytics{
		requestsByWebhook: make(map[string]*WebhookStats),
		requestsByMethod:  make(map[string]int64),
		requestsByStatus:  make(map[int]int64),
		recentRequests:    make([]*WebhookRequest, 0),
		maxRecentRequests: 100,
	}
}

func (wa *WebhookAnalytics) AddWebhook(webhookID string) {
	wa.mu.Lock()
	defer wa.mu.Unlock()

	wa.requestsByWebhook[webhookID] = &WebhookStats{}
}

func (wa *WebhookAnalytics) RemoveWebhook(webhookID string) {
	wa.mu.Lock()
	defer wa.mu.Unlock()

	delete(wa.requestsByWebhook, webhookID)
}

func (wa *WebhookAnalytics) RecordRequest(webhookID string, success bool, processingTime time.Duration) {
	wa.mu.Lock()
	defer wa.mu.Unlock()

	wa.totalRequests++
	wa.totalProcessingTime += processingTime
	wa.avgProcessingTime = wa.totalProcessingTime / time.Duration(wa.totalRequests)

	if success {
		wa.successfulRequests++
	} else {
		wa.failedRequests++
	}

	// Update webhook-specific stats
	if stats, exists := wa.requestsByWebhook[webhookID]; exists {
		stats.TotalRequests++
		if success {
			stats.SuccessfulRequests++
		} else {
			stats.FailedRequests++
		}
		stats.LastTriggered = time.Now()

		// Update response times (keep last 10)
		stats.ResponseTimes = append(stats.ResponseTimes, processingTime)
		if len(stats.ResponseTimes) > 10 {
			stats.ResponseTimes = stats.ResponseTimes[1:]
		}

		// Calculate average
		if stats.TotalRequests > 0 {
			var total time.Duration
			for _, rt := range stats.ResponseTimes {
				total += rt
			}
			stats.AvgProcessingTime = total / time.Duration(len(stats.ResponseTimes))
		}
	}
}

func (wa *WebhookAnalytics) AddRecentRequest(request *WebhookRequest) {
	wa.mu.Lock()
	defer wa.mu.Unlock()

	wa.recentRequests = append(wa.recentRequests, request)
	if len(wa.recentRequests) > wa.maxRecentRequests {
		wa.recentRequests = wa.recentRequests[1:]
	}
}

func (wa *WebhookAnalytics) GetStats() map[string]interface{} {
	wa.mu.RLock()
	defer wa.mu.RUnlock()

	return map[string]interface{}{
		"totalRequests":      wa.totalRequests,
		"successfulRequests": wa.successfulRequests,
		"failedRequests":     wa.failedRequests,
		"avgProcessingTime":  wa.avgProcessingTime.String(),
		"successRate":        float64(wa.successfulRequests) / float64(wa.totalRequests) * 100,
		"webhookStats":       wa.requestsByWebhook,
		"recentRequestCount": len(wa.recentRequests),
	}
}

// Event bus implementation

func NewEventBus() *EventBus {
	return &EventBus{
		subscribers: make(map[string][]chan *WebhookEvent),
	}
}

func (eb *EventBus) Subscribe(eventType string) <-chan *WebhookEvent {
	eb.mu.Lock()
	defer eb.mu.Unlock()

	ch := make(chan *WebhookEvent, 100)
	eb.subscribers[eventType] = append(eb.subscribers[eventType], ch)
	return ch
}

func (eb *EventBus) Publish(eventType string, event *WebhookEvent) {
	eb.mu.RLock()
	defer eb.mu.RUnlock()

	if subscribers, exists := eb.subscribers[eventType]; exists {
		for _, ch := range subscribers {
			select {
			case ch <- event:
			default:
				// Channel is full, skip
			}
		}
	}
}

// HTTP handlers for management API

func (wm *WebhookManager) handleListWebhooks(w http.ResponseWriter, r *http.Request) {
	webhooks := wm.ListWebhooks()
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"webhooks": webhooks,
		"count":    len(webhooks),
	})
}

func (wm *WebhookManager) handleCreateWebhook(w http.ResponseWriter, r *http.Request) {
	var config WebhookConfig
	if err := json.NewDecoder(r.Body).Decode(&config); err != nil {
		wm.sendErrorResponse(w, http.StatusBadRequest, "Invalid request body", err)
		return
	}

	if err := wm.CreateWebhook(&config); err != nil {
		wm.sendErrorResponse(w, http.StatusBadRequest, "Failed to create webhook", err)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(http.StatusCreated)
	json.NewEncoder(w).Encode(map[string]interface{}{
		"status":  "created",
		"webhook": config,
	})
}

func (wm *WebhookManager) handleGetWebhook(w http.ResponseWriter, r *http.Request) {
	vars := mux.Vars(r)
	webhookID := vars["id"]

	config, err := wm.GetWebhook(webhookID)
	if err != nil {
		wm.sendErrorResponse(w, http.StatusNotFound, "Webhook not found", err)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(config)
}

func (wm *WebhookManager) handleUpdateWebhook(w http.ResponseWriter, r *http.Request) {
	vars := mux.Vars(r)
	webhookID := vars["id"]

	var config WebhookConfig
	if err := json.NewDecoder(r.Body).Decode(&config); err != nil {
		wm.sendErrorResponse(w, http.StatusBadRequest, "Invalid request body", err)
		return
	}

	config.ID = webhookID
	if err := wm.UpdateWebhook(webhookID, &config); err != nil {
		wm.sendErrorResponse(w, http.StatusBadRequest, "Failed to update webhook", err)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"status":  "updated",
		"webhook": config,
	})
}

func (wm *WebhookManager) handleDeleteWebhook(w http.ResponseWriter, r *http.Request) {
	vars := mux.Vars(r)
	webhookID := vars["id"]

	if err := wm.DeleteWebhook(webhookID); err != nil {
		wm.sendErrorResponse(w, http.StatusNotFound, "Failed to delete webhook", err)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(map[string]interface{}{
		"status": "deleted",
		"id":     webhookID,
	})
}

func (wm *WebhookManager) handleGetAnalytics(w http.ResponseWriter, r *http.Request) {
	stats := wm.analytics.GetStats()
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(stats)
}

func (wm *WebhookManager) handleGetWebhookAnalytics(w http.ResponseWriter, r *http.Request) {
	vars := mux.Vars(r)
	webhookID := vars["id"]

	wm.analytics.mu.RLock()
	stats, exists := wm.analytics.requestsByWebhook[webhookID]
	wm.analytics.mu.RUnlock()

	if !exists {
		wm.sendErrorResponse(w, http.StatusNotFound, "Webhook analytics not found", nil)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(stats)
}

func (wm *WebhookManager) handleHealthCheck(w http.ResponseWriter, r *http.Request) {
	health := map[string]interface{}{
		"status":           "healthy",
		"webhookCount":     len(wm.webhooks),
		"totalRequests":    wm.analytics.totalRequests,
		"uptime":          time.Since(wm.analytics.requestsByWebhook["startup_time"].LastTriggered).String(),
		"memoryUsage":     "N/A", // Could add actual memory usage
	}

	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(health)
}