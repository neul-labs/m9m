}

func (n *TeamsNode) sendChatMessage(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	chatId := params.GetString("chatId")
	messageContent := params.GetString("content")

	if chatId == "" || messageContent == "" {
		return nil, fmt.Errorf("chatId and content are required")
	}

	body := map[string]interface{}{
		"body": map[string]interface{}{
			"content":     messageContent,
			"contentType": params.GetString("contentType", "text"),
		},
	}

	if importance := params.GetString("importance"); importance != "" {
		body["importance"] = importance
	}

	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, err
	}

	url := fmt.Sprintf("https://graph.microsoft.com/v1.0/chats/%s/messages", chatId)
	req, err := http.NewRequestWithContext(ctx, "POST", url, bytes.NewReader(jsonBody))
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusCreated {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to send chat message: %s", body)
	}

	var result map[string]interface{}
