	if teamId == "" || channelId == "" {
		return nil, fmt.Errorf("teamId and channelId are required")
	}

	body := map[string]interface{}{}
	if displayName := params.GetString("displayName"); displayName != "" {
		body["displayName"] = displayName
	}
	if description := params.GetString("description"); description != "" {
		body["description"] = description
	}

	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, err
	}

	url := fmt.Sprintf("https://graph.microsoft.com/v1.0/teams/%s/channels/%s", teamId, channelId)
	req, err := http.NewRequestWithContext(ctx, "PATCH", url, bytes.NewReader(jsonBody))
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to update channel: %s", body)
	}

	var result map[string]interface{}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, err
	}

	return result, nil
}

func (n *TeamsNode) deleteChannel(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	teamId := params.GetString("teamId")
	channelId := params.GetString("channelId")

	if teamId == "" || channelId == "" {
		return nil, fmt.Errorf("teamId and channelId are required")
	}

	url := fmt.Sprintf("https://graph.microsoft.com/v1.0/teams/%s/channels/%s", teamId, channelId)
	req, err := http.NewRequestWithContext(ctx, "DELETE", url, nil)
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusNoContent {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to delete channel: %s", body)
	}

	return map[string]bool{"success": true}, nil
}

// Message operations

func (n *TeamsNode) handleMessageResource(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	operation := params.GetString("operation")
	if operation == "" {
		operation = "send"
	}

	switch operation {
	case "send":
		return n.sendMessage(ctx, token, params)
	case "sendReply":
		return n.sendReply(ctx, token, params)
	case "get":
		return n.getMessage(ctx, token, params)
	case "getAll":
		return n.getAllMessages(ctx, token, params)
	case "update":
		return n.updateMessage(ctx, token, params)
	case "delete":
		return n.deleteMessage(ctx, token, params)
	default:
		return nil, fmt.Errorf("unsupported message operation: %s", operation)
	}
}

func (n *TeamsNode) sendMessage(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	teamId := params.GetString("teamId")
	channelId := params.GetString("channelId")
	messageContent := params.GetString("content")

	if teamId == "" || channelId == "" || messageContent == "" {
		return nil, fmt.Errorf("teamId, channelId, and content are required")
	}

	body := map[string]interface{}{
		"body": map[string]interface{}{
			"content": messageContent,
		},
	}

	// Add content type
	contentType := params.GetString("contentType", "text")
	body["body"].(map[string]interface{})["contentType"] = contentType

	// Add importance if specified
	if importance := params.GetString("importance"); importance != "" {
		body["importance"] = importance
	}

	// Add mentions if specified
	if mentions := params.Get("mentions"); mentions != nil {
		body["mentions"] = mentions
	}

	// Add attachments if specified
	if attachments := params.Get("attachments"); attachments != nil {
		body["attachments"] = attachments
	}

	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, err
	}

	url := fmt.Sprintf("https://graph.microsoft.com/v1.0/teams/%s/channels/%s/messages", teamId, channelId)
	req, err := http.NewRequestWithContext(ctx, "POST", url, bytes.NewReader(jsonBody))
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusCreated {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to send message: %s", body)
	}

	var result map[string]interface{}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, err
	}

	return result, nil
}

func (n *TeamsNode) sendReply(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	teamId := params.GetString("teamId")
	channelId := params.GetString("channelId")
	messageId := params.GetString("messageId")
	replyContent := params.GetString("content")

	if teamId == "" || channelId == "" || messageId == "" || replyContent == "" {
		return nil, fmt.Errorf("teamId, channelId, messageId, and content are required")
	}

	body := map[string]interface{}{
		"body": map[string]interface{}{
			"content": replyContent,
		},
	}

	contentType := params.GetString("contentType", "text")
	body["body"].(map[string]interface{})["contentType"] = contentType

	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, err
	}

	url := fmt.Sprintf("https://graph.microsoft.com/v1.0/teams/%s/channels/%s/messages/%s/replies",
		teamId, channelId, messageId)
	req, err := http.NewRequestWithContext(ctx, "POST", url, bytes.NewReader(jsonBody))
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusCreated {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to send reply: %s", body)
	}

	var result map[string]interface{}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, err
	}

	return result, nil
}

func (n *TeamsNode) getMessage(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	teamId := params.GetString("teamId")
	channelId := params.GetString("channelId")
	messageId := params.GetString("messageId")

	if teamId == "" || channelId == "" || messageId == "" {
