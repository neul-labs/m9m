func (n *TeamsNode) updateTask(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	taskId := params.GetString("taskId")
	etag := params.GetString("@odata.etag")

	if taskId == "" || etag == "" {
		return nil, fmt.Errorf("taskId and @odata.etag are required")
	}

	body := map[string]interface{}{}
	if title := params.GetString("title"); title != "" {
		body["title"] = title
	}
	if percentComplete := params.GetInt("percentComplete"); percentComplete >= 0 {
		body["percentComplete"] = percentComplete
	}
	if dueDateTime := params.GetString("dueDateTime"); dueDateTime != "" {
		body["dueDateTime"] = dueDateTime
	}

	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, err
	}

	url := fmt.Sprintf("https://graph.microsoft.com/v1.0/planner/tasks/%s", taskId)
	req, err := http.NewRequestWithContext(ctx, "PATCH", url, bytes.NewReader(jsonBody))
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")
	req.Header.Set("If-Match", etag)

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusNoContent {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to update task: %s", body)
	}

	return map[string]bool{"success": true}, nil
}

