func (n *TeamsNode) updateMessage(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	// Note: Microsoft Teams API doesn't support updating messages in channels
	// This is primarily for chat messages
	return nil, fmt.Errorf("message updates are not supported in Teams channels")
}

func (n *TeamsNode) deleteMessage(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	// Note: Microsoft Teams API doesn't support deleting messages
	return nil, fmt.Errorf("message deletion is not supported in Teams")
}

// Chat operations

func (n *TeamsNode) handleChatResource(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	operation := params.GetString("operation")
	if operation == "" {
		operation = "get"
	}

	switch operation {
	case "create":
		return n.createChat(ctx, token, params)
	case "get":
		return n.getChat(ctx, token, params)
	case "getAll":
		return n.getAllChats(ctx, token, params)
	case "sendMessage":
		return n.sendChatMessage(ctx, token, params)
	case "getMembers":
		return n.getChatMembers(ctx, token, params)
	case "addMember":
		return n.addChatMember(ctx, token, params)
	default:
		return nil, fmt.Errorf("unsupported chat operation: %s", operation)
	}
}

func (n *TeamsNode) createChat(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	chatType := params.GetString("chatType", "oneOnOne")
	members := params.GetSlice("members")

	if len(members) == 0 {
		return nil, fmt.Errorf("at least one member is required")
	}

	body := map[string]interface{}{
		"chatType": chatType,
		"members":  members,
	}

	if topic := params.GetString("topic"); topic != "" && chatType == "group" {
		body["topic"] = topic
	}

	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, err
	}

	req, err := http.NewRequestWithContext(ctx, "POST", "https://graph.microsoft.com/v1.0/chats", bytes.NewReader(jsonBody))
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusCreated {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to create chat: %s", body)
	}

	var result map[string]interface{}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, err
	}

	return result, nil
}

func (n *TeamsNode) getChat(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	chatId := params.GetString("chatId")
	if chatId == "" {
		return nil, fmt.Errorf("chatId is required")
	}

	url := fmt.Sprintf("https://graph.microsoft.com/v1.0/chats/%s", chatId)
	req, err := http.NewRequestWithContext(ctx, "GET", url, nil)
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to get chat: %s", body)
	}

	var result map[string]interface{}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, err
	}

	return result, nil
}

