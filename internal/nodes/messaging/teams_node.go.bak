func (n *TeamsNode) createTask(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	planId := params.GetString("planId")
	title := params.GetString("title")

	if planId == "" || title == "" {
		return nil, fmt.Errorf("planId and title are required")
	}

	body := map[string]interface{}{
		"planId": planId,
		"title":  title,
	}

	// Add optional fields
	if bucketId := params.GetString("bucketId"); bucketId != "" {
		body["bucketId"] = bucketId
	}
	if dueDateTime := params.GetString("dueDateTime"); dueDateTime != "" {
		body["dueDateTime"] = dueDateTime
	}
	if assigneePriority := params.GetString("assigneePriority"); assigneePriority != "" {
		body["assigneePriority"] = assigneePriority
	}

	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, err
	}

	req, err := http.NewRequestWithContext(ctx, "POST", "https://graph.microsoft.com/v1.0/planner/tasks", bytes.NewReader(jsonBody))
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusCreated {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to create task: %s", body)
	}

	var result map[string]interface{}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, err
	}

	return result, nil
}

