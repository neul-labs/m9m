package messaging

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"net/url"
	"strings"
	"time"

	"github.com/dipankar/n8n-go/internal/nodes/base"
)

// TeamsNode provides Microsoft Teams integration
type TeamsNode struct {
	*base.BaseNode
	httpClient *http.Client
}

// NewTeamsNode creates a new Teams node
func NewTeamsNode() base.Node {
	return &TeamsNode{
		BaseNode: base.NewBaseNode("Teams"),
		httpClient: &http.Client{
			Timeout: 30 * time.Second,
		},
	}
}

// GetMetadata returns node metadata
func (n *TeamsNode) GetMetadata() base.NodeMetadata {
	return base.NodeMetadata{
		Name:        "Microsoft Teams",
		Version:     "1.0.0",
		Description: "Send messages and interact with Microsoft Teams",
		Icon:        "teams",
		Category:    "Communication",
		Credentials: []base.CredentialType{
			{
				Name: "microsoftTeamsOAuth2Api",
				Type: "oauth2",
			},
		},
		Properties: []base.NodeProperty{
			{
				Name:        "resource",
				Type:        "options",
				DisplayName: "Resource",
				Description: "The resource to operate on",
				Options: []base.PropertyOption{
					{Name: "Channel", Value: "channel"},
					{Name: "Chat", Value: "chat"},
					{Name: "Message", Value: "message"},
					{Name: "Team", Value: "team"},
					{Name: "Task", Value: "task"},
				},
				Default:  "message",
				Required: true,
			},
		},
	}
}

// Execute runs the node
func (n *TeamsNode) Execute(ctx context.Context, params base.ExecutionParams) (base.NodeOutput, error) {
	resource := params.GetString("resource")
	if resource == "" {
		resource = "message"
	}

	var result interface{}
	var err error

	// Get access token
	accessToken, err := n.getAccessToken(params)
	if err != nil {
		return nil, fmt.Errorf("failed to get access token: %w", err)
	}

	switch resource {
	case "channel":
		result, err = n.handleChannelResource(ctx, accessToken, params)
	case "chat":
		result, err = n.handleChatResource(ctx, accessToken, params)
	case "message":
		result, err = n.handleMessageResource(ctx, accessToken, params)
	case "team":
		result, err = n.handleTeamResource(ctx, accessToken, params)
	case "task":
		result, err = n.handleTaskResource(ctx, accessToken, params)
	default:
		return nil, fmt.Errorf("unsupported resource: %s", resource)
	}

	if err != nil {
		return nil, err
	}

	return &base.NodeOutput{
		Data: result,
	}, nil
}

func (n *TeamsNode) getAccessToken(params base.ExecutionParams) (string, error) {
	// Check for OAuth2 access token
	if token := params.GetString("credentials.accessToken"); token != "" {
		return token, nil
	}

	// Check for client credentials
	clientId := params.GetString("credentials.clientId")
	clientSecret := params.GetString("credentials.clientSecret")
	tenantId := params.GetString("credentials.tenantId")

	if clientId != "" && clientSecret != "" && tenantId != "" {
		return n.getClientCredentialsToken(clientId, clientSecret, tenantId)
	}

	return "", fmt.Errorf("no valid credentials provided")
}

func (n *TeamsNode) getClientCredentialsToken(clientId, clientSecret, tenantId string) (string, error) {
	tokenUrl := fmt.Sprintf("https://login.microsoftonline.com/%s/oauth2/v2.0/token", tenantId)

	data := url.Values{}
	data.Set("client_id", clientId)
	data.Set("client_secret", clientSecret)
	data.Set("scope", "https://graph.microsoft.com/.default")
	data.Set("grant_type", "client_credentials")

	resp, err := n.httpClient.Post(tokenUrl, "application/x-www-form-urlencoded", strings.NewReader(data.Encode()))
	if err != nil {
		return "", err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		body, _ := io.ReadAll(resp.Body)
		return "", fmt.Errorf("failed to get access token: %s", body)
	}

	var tokenResp struct {
		AccessToken string `json:"access_token"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&tokenResp); err != nil {
		return "", err
	}

	return tokenResp.AccessToken, nil
}

// Channel operations

func (n *TeamsNode) handleChannelResource(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	operation := params.GetString("operation")
	if operation == "" {
		operation = "get"
	}

	switch operation {
	case "create":
		return n.createChannel(ctx, token, params)
	case "delete":
		return n.deleteChannel(ctx, token, params)
	case "get":
		return n.getChannel(ctx, token, params)
	case "getAll":
		return n.getAllChannels(ctx, token, params)
	case "update":
		return n.updateChannel(ctx, token, params)
	default:
		return nil, fmt.Errorf("unsupported channel operation: %s", operation)
	}
}

func (n *TeamsNode) createChannel(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	teamId := params.GetString("teamId")
	if teamId == "" {
		return nil, fmt.Errorf("teamId is required")
	}

	body := map[string]interface{}{
		"displayName": params.GetString("displayName"),
		"description": params.GetString("description"),
	}

	if membershipType := params.GetString("membershipType"); membershipType != "" {
		body["membershipType"] = membershipType
	}

	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, err
	}

	url := fmt.Sprintf("https://graph.microsoft.com/v1.0/teams/%s/channels", teamId)
	req, err := http.NewRequestWithContext(ctx, "POST", url, bytes.NewReader(jsonBody))
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusCreated {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to create channel: %s", body)
	}

	var result map[string]interface{}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, err
	}

	return result, nil
}

func (n *TeamsNode) getChannel(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	teamId := params.GetString("teamId")
	channelId := params.GetString("channelId")

	if teamId == "" || channelId == "" {
		return nil, fmt.Errorf("teamId and channelId are required")
	}

	url := fmt.Sprintf("https://graph.microsoft.com/v1.0/teams/%s/channels/%s", teamId, channelId)
	req, err := http.NewRequestWithContext(ctx, "GET", url, nil)
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to get channel: %s", body)
	}

	var result map[string]interface{}
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, err
	}

	return result, nil
}

