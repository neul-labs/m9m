// Team operations

func (n *TeamsNode) handleTeamResource(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	operation := params.GetString("operation")
	if operation == "" {
		operation = "get"
	}

	switch operation {
	case "create":
		return n.createTeam(ctx, token, params)
	case "get":
		return n.getTeam(ctx, token, params)
	case "getAll":
		return n.getAllTeams(ctx, token, params)
	case "update":
		return n.updateTeam(ctx, token, params)
	case "delete":
		return n.deleteTeam(ctx, token, params)
	case "getMembers":
		return n.getTeamMembers(ctx, token, params)
	case "addMember":
		return n.addTeamMember(ctx, token, params)
	default:
		return nil, fmt.Errorf("unsupported team operation: %s", operation)
	}
}

func (n *TeamsNode) createTeam(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	displayName := params.GetString("displayName")
	description := params.GetString("description")

	if displayName == "" {
		return nil, fmt.Errorf("displayName is required")
	}

	body := map[string]interface{}{
		"template@odata.bind": "https://graph.microsoft.com/v1.0/teamsTemplates('standard')",
		"displayName":        displayName,
		"description":        description,
	}

	// Add visibility
	if visibility := params.GetString("visibility"); visibility != "" {
		body["visibility"] = visibility
	}

	// Add members if specified
	if members := params.GetSlice("members"); len(members) > 0 {
		body["members"] = members
	}

	jsonBody, err := json.Marshal(body)
	if err != nil {
		return nil, err
	}

	req, err := http.NewRequestWithContext(ctx, "POST", "https://graph.microsoft.com/v1.0/teams", bytes.NewReader(jsonBody))
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")

	resp, err := n.httpClient.Do(req)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	// Team creation returns 202 with Location header
	if resp.StatusCode != http.StatusAccepted {
		body, _ := io.ReadAll(resp.Body)
		return nil, fmt.Errorf("failed to create team: %s", body)
	}

	// Return the location header which contains the operation URL
	return map[string]interface{}{
		"operationLocation": resp.Header.Get("Location"),
		"status":            "accepted",
	}, nil
}

func (n *TeamsNode) getTeam(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
