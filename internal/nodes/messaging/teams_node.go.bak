}

func (n *TeamsNode) getAllTeams(ctx context.Context, token string, params base.ExecutionParams) (interface{}, error) {
	url := "https://graph.microsoft.com/v1.0/me/joinedTeams"

	// Add query parameters
	queryParams := url.Values{}
	if top := params.GetInt("$top"); top > 0 {
		queryParams.Set("$top", fmt.Sprintf("%d", top))
	}
	if filter := params.GetString("$filter"); filter != "" {
		queryParams.Set("$filter", filter)
	}

	if len(queryParams) > 0 {
		url += "?" + queryParams.Encode()
	}

	req, err := http.NewRequestWithContext(ctx, "GET", url, nil)
	if err != nil {
		return nil, err
	}

	req.Header.Set("Authorization", "Bearer "+token)

	resp, err := n.httpClient.Do(req)
	if err != nil {
